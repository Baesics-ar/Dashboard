# ── Database (Railway injects DATABASE_URL automatically) ─────────────────────
# For local dev: create a local Postgres DB and set this manually
DATABASE_URL=postgresql://user:password@localhost:5432/studiopro

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Optional: Frontend URL for CORS in dev
# FRONTEND_URL=http://localhost:5173
